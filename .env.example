# Copy this file to .env and fill in your values.
# Never commit the real .env file — add it to .gitignore!

# Django secret key — generate a fresh one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to True for local development, False for production
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# DATABASE_URL — two options:
#
# Option A — Local development (recommended for your laptop):
#   Leave blank. Django will use a local SQLite file (db.sqlite3) automatically.
#   No Postgres installation needed!
DATABASE_URL=
#
# Option B — Production / Railway:
#   Paste the PUBLIC Postgres URL from Railway (not the internal one).
#   Go to Railway → your Postgres service → Connect tab → copy "Public URL".
#   It looks like: postgresql://postgres:<password>@<host>.railway.app:PORT/railway
#   WARNING: The "postgres.railway.internal" hostname only works inside Railway's
#   servers — it will NOT connect from your local machine.
# DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway
